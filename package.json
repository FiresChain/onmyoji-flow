{
  "name": "@rookie4show/onmyoji-flow",
  "version": "0.1.2",
  "description": "Onmyoji flow editor - standalone and embeddable component",
  "author": "fireschain",
  "license": "MIT",
  "type": "module",
  "main": "./dist/onmyoji-flow.umd.js",
  "module": "./dist/onmyoji-flow.es.js",
  "exports": {
    ".": {
      "import": "./dist/onmyoji-flow.es.js",
      "require": "./dist/onmyoji-flow.umd.js"
    },
    "./style.css": "./dist/onmyoji-flow.css"
  },
  "files": [
    "dist/onmyoji-flow.css",
    "dist/onmyoji-flow.es.js",
    "dist/onmyoji-flow.es.js.map",
    "dist/onmyoji-flow.umd.js",
    "dist/onmyoji-flow.umd.js.map"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.config.lib.js",
    "build:app": "vite build --outDir dist-app",
    "build:pages": "vite build --base /onmyoji-flow/ --outDir dist-app",
    "build:lib": "vite build --config vite.config.lib.js",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --rulesdir ./eslint-rules --ignore-path .gitignore && npm run lint:active-file-boundary && npm run lint:compat-freeze",
    "lint:fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --rulesdir ./eslint-rules --fix --ignore-path .gitignore && npm run lint:active-file-boundary && npm run lint:compat-freeze",
    "lint:active-file-boundary": "eslint src/ts/useStore.ts --ext .ts --rulesdir ./eslint-rules --ignore-path .gitignore",
    "lint:compat-freeze": "node scripts/check-logicflow-compat-freeze.cjs",
    "format": "prettier --write src/",
    "format:check": "prettier --check \"src/**/*.{js,ts,vue}\"",
    "precommit": "npm test && npm run lint",
    "typecheck": "vue-tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vue": "^3.3.0",
    "element-plus": "^2.9.0",
    "pinia": "^3.0.0",
    "@logicflow/core": "^2.0.0",
    "@logicflow/extension": "^2.0.0",
    "@logicflow/vue-node-registry": "^1.0.0"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@logicflow/core": "^2.0.16",
    "@logicflow/engine": "^0.1.1",
    "@logicflow/extension": "^2.0.21",
    "@logicflow/vue-node-registry": "^1.0.18",
    "@tailwindcss/postcss": "^4.1.11",
    "@vueup/vue-quill": "^1.2.0",
    "element-plus": "^2.9.1",
    "html2canvas": "^1.4.1",
    "jsqr": "^1.4.0",
    "pinia": "^3.0.1",
    "vue": "^3.3.10",
    "vue-i18n": "^11.1.1",
    "vue3-draggable-resizable": "^1.6.5",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.3.3",
    "@vitejs/plugin-vue": "^4.5.1",
    "@vitest/ui": "^4.0.18",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.49.0",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint-plugin-vue": "^9.17.0",
    "happy-dom": "^20.6.1",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.0.3",
    "typescript": "^5.9.3",
    "vite": "^5.0.5",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  }
}
