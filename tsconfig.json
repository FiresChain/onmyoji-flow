{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@logicflow/core": ["./src/types/logicflow-core-compat.d.ts"],
      "@logicflow/extension": ["./src/types/logicflow-extension-compat.d.ts"],
      "@logicflow/vue-node-registry": ["./src/types/logicflow-vue-node-registry-compat.d.ts"]
    },
    "allowJs": true,
    "checkJs": false,
    "jsx": "preserve",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "src/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist", "dist-app"]
}
